# Server
PORT=8000
NODE_ENV=development

# Database (PostgreSQL)
PGUSER=your_pg_user
PGHOST=localhost
PGPASSWORD=your_pg_password
PGDATABASE=nawasenadara
PGPORT=5432
# Alternatif: kalau hosting menyediakan satu connection string (Railway/Render dll),
# pakai ini saja dan hapus/abaikan PG* di atas.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT — WAJIB pakai secret yang BEDA untuk access & refresh token
JWT_ACCESS_SECRET=ganti_dengan_random_string_min_32_karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ganti_dengan_random_string_lain_min_32_karakter
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (dipakai untuk verifikasi ID token dari Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Frontend URL — dipakai untuk whitelist CORS & link reset password
FRONTEND_URL=http://localhost:3000

# Email — SMTP via Nodemailer (untuk fitur Lupa Password)
# Contoh Gmail: host=smtp.gmail.com, port=587, secure=false, user=email gmail,
# pass=App Password (BUKAN password akun biasa — buat di
# https://myaccount.google.com/apppasswords, wajib 2FA aktif dulu)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nawasenadara@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Nawasena Dara <nawasenadara@gmail.com>
